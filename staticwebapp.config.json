{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/assets/*",
      "/*.json",
      "/*.txt",
      "/*.js",
      "/*.css",
      "/*.mjs",
      "/*.map"
    ]
  },
  "mobileApiLocation": "api",
  "responseOverrides": {
    "404": {
      "rewrite": "/index.html",
      "statusCode": 200
    }
  }
}
